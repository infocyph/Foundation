{
    "name": "infocyph/foundation",
    "description": "Illuminate-style integration foundation for the Infocyph PHP ecosystem.",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.4",
        "infocyph/console": "dev-main@dev",
        "infocyph/webrick": "^2.02.1",
        "web-auth/webauthn-lib": "^5.3.5"
    },
    "require-dev": {
        "infocyph/phpforge": "dev-main@dev"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Infocyph\\Foundation\\": "src/"
        },
        "files": [
            "src/Config/config_helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Infocyph\\Foundation\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infocyph/phpforge": true,
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
